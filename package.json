{
  "name": "@creatornader/agent-bridge",
  "version": "0.3.0",
  "description": "Durable, pull-first mailbox and work-delivery control plane for AI agents across runtimes, sessions, and machines.",
  "type": "module",
  "license": "Apache-2.0",
  "author": "Nader Helmy",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/creatornader/agent-bridge.git"
  },
  "homepage": "https://github.com/creatornader/agent-bridge#readme",
  "bugs": {
    "url": "https://github.com/creatornader/agent-bridge/issues"
  },
  "engines": {
    "node": ">=22.23.1"
  },
  "main": "dist/bridge.js",
  "bin": {
    "agent-bridge": "bin/agent-bridge",
    "agent-bridge-mcp": "dist/index.js",
    "agent-bridge-gateway": "dist/gateway-main.js"
  },
  "files": [
    "dist",
    "bin",
    "clients",
    "schemas",
    "openapi",
    "docs",
    "sql/migrations",
    "sql/setup.sql",
    "llms.txt",
    "SKILL.md",
    "README.md",
    "ROADMAP.md",
    "SECURITY.md",
    "CHANGELOG.md",
    "LICENSE"
  ],
  "exports": {
    ".": {
      "types": "./dist/bridge.d.ts",
      "import": "./dist/bridge.js"
    },
    "./server": {
      "types": "./dist/server.d.ts",
      "import": "./dist/server.js"
    },
    "./bridge": {
      "types": "./dist/bridge.d.ts",
      "import": "./dist/bridge.js"
    },
    "./gateway": {
      "types": "./dist/gateway.d.ts",
      "import": "./dist/gateway.js"
    },
    "./sqlite": {
      "types": "./dist/sqlite.d.ts",
      "import": "./dist/sqlite.js"
    },
    "./client": {
      "types": "./dist/client-runtime.d.ts",
      "import": "./dist/client-runtime.js"
    },
    "./config": {
      "types": "./dist/client-config.d.ts",
      "import": "./dist/client-config.js"
    },
    "./archive": {
      "types": "./dist/archive.d.ts",
      "import": "./dist/archive.js"
    },
    "./dr": {
      "types": "./dist/dr.d.ts",
      "import": "./dist/dr.js"
    }
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "start": "node dist/index.js",
    "start:gateway": "node dist/gateway-main.js",
    "migrate": "node dist/gateway-main.js --migrate-only",
    "prepack": "npm run build && npm run contracts:check:built",
    "pretest": "npm run build",
    "test": "vitest run",
    "test:built": "vitest run",
    "typecheck": "tsc --noEmit",
    "contracts:generate": "npm run build --silent && npm run contracts:generate:built",
    "contracts:generate:built": "node dist/contracts/generate.js",
    "contracts:check": "npm run build --silent && npm run contracts:check:built",
    "contracts:check:built": "node dist/contracts/generate.js --check",
    "check": "npm run typecheck && npm run build && npm run contracts:check:built && npm run test:built",
    "check:windows": "npm run typecheck && npm run build && npm run contracts:check:built && vitest run --maxWorkers=2 --testTimeout=90000"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.1",
    "@sinclair/typebox": "npm:typebox@1.3.6",
    "pg": "^8.22.0"
  },
  "devDependencies": {
    "@types/node": "^26.1.0",
    "@types/pg": "^8.20.0",
    "tsup": "^8.4.0",
    "typescript": "^6.0.3",
    "vitest": "^4.1.9"
  },
  "overrides": {
    "esbuild": "0.28.1"
  },
  "directories": {
    "doc": "docs",
    "test": "test"
  },
  "keywords": [
    "agents",
    "mcp",
    "messaging",
    "coordination"
  ],
  "types": "./dist/bridge.d.ts"
}
