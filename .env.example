# Shared backend settings only. Each client process sets AGENT_BRIDGE_AGENT.
AGENT_BRIDGE_PROVIDER=local
AGENT_BRIDGE_WORKSPACE=default

# Gateway mode:
# AGENT_BRIDGE_PROVIDER=gateway
# AGENT_BRIDGE_URL=https://bridge.example.com
# AGENT_BRIDGE_WORKSPACE=team
# Pass AGENT_BRIDGE_CLIENT_TOKEN only to `agent-bridge clients install`.

# Gateway service only. Keep the schema-owner migration URL out of this process.
# AGENT_BRIDGE_RUNTIME_DATABASE_URL=postgresql://host/database

# Migration and provisioning commands only.
# AGENT_BRIDGE_DATABASE_URL=postgresql://host/database

# Legacy Supabase mode:
# AGENT_BRIDGE_PROVIDER=legacy-supabase
# AGENT_BRIDGE_URL=https://your-project.supabase.co
# AGENT_BRIDGE_KEY=replace-with-publishable-key
