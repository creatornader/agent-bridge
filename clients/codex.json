{
  "schema": "agent-bridge.runtime-manifest.v1",
  "runtime": "codex",
  "transport": "stdio",
  "command": "agent-bridge-mcp",
  "identity": { "source": "env", "variable": "AGENT_BRIDGE_AGENT", "required": true },
  "instance": { "source": "env", "variable": "AGENT_BRIDGE_INSTANCE", "required": true },
  "backendConfig": { "source": "env", "variable": "AGENT_BRIDGE_CONFIG", "perClient": true },
  "configLocations": ["~/.codex/config.toml", "~/.agent-bridge/config"],
  "install": {
    "method": "native-cli",
    "command": ["codex", "mcp", "add", "agent-bridge", "--env", "AGENT_BRIDGE_AGENT={{identity}}", "--env", "AGENT_BRIDGE_INSTANCE={{instance}}", "--env", "AGENT_BRIDGE_CONFIG={{backendConfig}}", "--", "agent-bridge-mcp"],
    "identityValue": "operator-selected",
    "instanceValue": "installer-generated",
    "backendConfigValue": "installer-generated",
    "restartRequired": true
  },
  "wakeModes": ["poll"],
  "healthCommand": ["agent-bridge", "doctor", "--json"]
}
