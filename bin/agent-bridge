#!/usr/bin/env bash
# agent-bridge — CLI for shared context between AI agents
# Uses curl to hit Supabase REST API directly.
# Config: ~/.agent-bridge/config (AGENT_BRIDGE_URL, AGENT_BRIDGE_KEY)

set -euo pipefail

CONFIG_FILE="${HOME}/.agent-bridge/config"

if [[ ! -f "$CONFIG_FILE" ]]; then
  echo "Error: Config file not found at $CONFIG_FILE" >&2
  echo "Create it with AGENT_BRIDGE_URL and AGENT_BRIDGE_KEY" >&2
  exit 1
fi

# shellcheck source=/dev/null
source "$CONFIG_FILE"

if [[ -z "${AGENT_BRIDGE_URL:-}" || -z "${AGENT_BRIDGE_KEY:-}" ]]; then
  echo "Error: AGENT_BRIDGE_URL and AGENT_BRIDGE_KEY must be set in $CONFIG_FILE" >&2
  exit 1
fi

REST_URL="${AGENT_BRIDGE_URL}/rest/v1"

sb_request() {
  local method="$1" path="$2"
  shift 2
  curl -s -X "$method" "${REST_URL}${path}" \
    -H "apikey: ${AGENT_BRIDGE_KEY}" \
    -H "Authorization: Bearer ${AGENT_BRIDGE_KEY}" \
    -H "Content-Type: application/json" \
    -H "Prefer: return=representation" \
    "$@"
}

usage() {
  cat <<'EOF'
agent-bridge — shared context between AI agents

Commands:
  post    Post a context entry
  get     Read context entries
  ack     Acknowledge entries
  status  Health check

Post:
  AGENT_BRIDGE_AGENT=codex agent-bridge post --category operational "Morning briefing delivered"
  agent-bridge post --source sido --category operational "Morning briefing delivered"
  agent-bridge post --source sido --category bridge-meta "get_context should support multi-category filter"
  agent-bridge post --source claude-code --category config-change --project whop-app "Updated API route"
  agent-bridge post --source codex --category goal-update --target-agent sido --thread-id loop-5 "Ready for handoff"

Get:
  agent-bridge get
  agent-bridge get --since 24h
  agent-bridge get --unacked-by sido
  agent-bridge get --category bridge-meta
  agent-bridge get --source claude-code --limit 5

Ack:
  agent-bridge ack --ids 1,2,3 --agent sido

Status:
  agent-bridge status
EOF
}

cmd_post() {
  local source="" category="" content="" priority="info" project="" metadata="{}"
  local message_id="" target_agents="" thread_id="" reply_to_id="" kind=""
  local payload_mime="text/plain" payload_ref="" payload_ciphertext=""
  local informed_by="" expires_at="" atrib_receipt_id=""

  while [[ $# -gt 0 ]]; do
    case "$1" in
      --source)             source="$2"; shift 2 ;;
      --category)           category="$2"; shift 2 ;;
      --priority)           priority="$2"; shift 2 ;;
      --project)            project="$2"; shift 2 ;;
      --metadata)           metadata="$2"; shift 2 ;;
      --message-id)         message_id="$2"; shift 2 ;;
      --target-agent)       target_agents="${target_agents:+$target_agents,}$2"; shift 2 ;;
      --target-agents)      target_agents="$2"; shift 2 ;;
      --thread-id)          thread_id="$2"; shift 2 ;;
      --reply-to-id)        reply_to_id="$2"; shift 2 ;;
      --kind)               kind="$2"; shift 2 ;;
      --payload-mime)       payload_mime="$2"; shift 2 ;;
      --payload-ref)        payload_ref="$2"; shift 2 ;;
      --payload-ciphertext) payload_ciphertext="$2"; shift 2 ;;
      --informed-by)        informed_by="$2"; shift 2 ;;
      --expires-at)         expires_at="$2"; shift 2 ;;
      --atrib-receipt-id)   atrib_receipt_id="$2"; shift 2 ;;
      -*)                   echo "Unknown option: $1" >&2; exit 1 ;;
      *)                    content="$1"; shift ;;
    esac
  done

  if [[ -n "${AGENT_BRIDGE_AGENT:-}" ]]; then
    if [[ -z "$source" ]]; then
      source="$AGENT_BRIDGE_AGENT"
    elif [[ "$source" != "$AGENT_BRIDGE_AGENT" ]]; then
      echo "Error: --source must match AGENT_BRIDGE_AGENT ($AGENT_BRIDGE_AGENT); got $source" >&2
      exit 1
    fi
  fi

  if [[ -z "$source" || -z "$category" || -z "$content" ]]; then
    echo "Error: --category and content are required; --source is required only when AGENT_BRIDGE_AGENT is unset" >&2
    exit 1
  fi

  local body
  body=$(
    BRIDGE_SOURCE="$source" \
    BRIDGE_CATEGORY="$category" \
    BRIDGE_CONTENT="$content" \
    BRIDGE_PRIORITY="$priority" \
    BRIDGE_PROJECT="$project" \
    BRIDGE_METADATA="$metadata" \
    BRIDGE_MESSAGE_ID="$message_id" \
    BRIDGE_TARGET_AGENTS="$target_agents" \
    BRIDGE_THREAD_ID="$thread_id" \
    BRIDGE_REPLY_TO_ID="$reply_to_id" \
    BRIDGE_KIND="$kind" \
    BRIDGE_PAYLOAD_MIME="$payload_mime" \
    BRIDGE_PAYLOAD_REF="$payload_ref" \
    BRIDGE_PAYLOAD_CIPHERTEXT="$payload_ciphertext" \
    BRIDGE_INFORMED_BY="$informed_by" \
    BRIDGE_EXPIRES_AT="$expires_at" \
    BRIDGE_ATRIB_RECEIPT_ID="$atrib_receipt_id" \
    python3 <<'PY'
import json
import os
import re
import uuid
from datetime import datetime, timezone

RECORD_HASH_RE = re.compile(r"^sha256:[a-f0-9]{64}$", re.I)
RECEIPT_RE = re.compile(r"^[A-Za-z0-9_-]{43}\\.[A-Za-z0-9_-]{43}$")

def clean(value):
    value = (value or "").strip()
    return value or None

def clean_list(value):
    out = []
    seen = set()
    for item in (value or "").split(","):
        item = item.strip()
        if item and item not in seen:
            seen.add(item)
            out.append(item)
    return out or None

def clean_hashes(value):
    out = []
    seen = set()
    for item in (value or "").split(","):
        item = item.strip().lower()
        if RECORD_HASH_RE.match(item) and item not in seen:
            seen.add(item)
            out.append(item)
    return out or None

def clean_time(value):
    value = clean(value)
    if not value:
        return None
    try:
        normalized = value.replace("Z", "+00:00")
        return datetime.fromisoformat(normalized).astimezone(timezone.utc).isoformat().replace("+00:00", "Z")
    except ValueError:
        return None

metadata_raw = os.environ.get("BRIDGE_METADATA") or "{}"
try:
    metadata = json.loads(metadata_raw)
    if not isinstance(metadata, dict):
        metadata = {}
except json.JSONDecodeError:
    metadata = {}

source = os.environ["BRIDGE_SOURCE"]
category = os.environ["BRIDGE_CATEGORY"]
kind = clean(os.environ.get("BRIDGE_KIND")) or category

envelope = {
    "schema": "agent-bridge.message-envelope.v1",
    "message_id": clean(os.environ.get("BRIDGE_MESSAGE_ID")) or str(uuid.uuid4()),
    "source_agent": source,
    "kind": kind,
    "priority": clean(os.environ.get("BRIDGE_PRIORITY")) or "info",
    "payload_mime": clean(os.environ.get("BRIDGE_PAYLOAD_MIME")) or "text/plain",
}

for key, env_name in [
    ("project", "BRIDGE_PROJECT"),
    ("thread_id", "BRIDGE_THREAD_ID"),
    ("reply_to_id", "BRIDGE_REPLY_TO_ID"),
    ("payload_ref", "BRIDGE_PAYLOAD_REF"),
    ("payload_ciphertext", "BRIDGE_PAYLOAD_CIPHERTEXT"),
]:
    value = clean(os.environ.get(env_name))
    if value:
        envelope[key] = value

receipt = clean(os.environ.get("BRIDGE_ATRIB_RECEIPT_ID"))
if receipt and RECEIPT_RE.match(receipt):
    envelope["atrib_receipt_id"] = receipt

targets = clean_list(os.environ.get("BRIDGE_TARGET_AGENTS"))
if targets:
    envelope["target_agents"] = targets

hashes = clean_hashes(os.environ.get("BRIDGE_INFORMED_BY"))
if hashes:
    envelope["informed_by"] = hashes

expires_at = clean_time(os.environ.get("BRIDGE_EXPIRES_AT"))
if expires_at:
    envelope["expires_at"] = expires_at

metadata["message_envelope"] = envelope

body = {
    "source": source,
    "category": category,
    "content": os.environ["BRIDGE_CONTENT"],
    "priority": clean(os.environ.get("BRIDGE_PRIORITY")) or "info",
    "project": clean(os.environ.get("BRIDGE_PROJECT")),
    "metadata": metadata,
}

if receipt and RECEIPT_RE.match(receipt):
    body["atrib_receipt_id"] = receipt

print(json.dumps(body))
PY
  )

  sb_request POST "/shared_context" -d "$body"
  echo ""
}

cmd_get() {
  local since="" source="" category="" project="" unacked_by="" limit="20"

  while [[ $# -gt 0 ]]; do
    case "$1" in
      --since)      since="$2"; shift 2 ;;
      --source)     source="$2"; shift 2 ;;
      --category)   category="$2"; shift 2 ;;
      --project)    project="$2"; shift 2 ;;
      --unacked-by) unacked_by="$2"; shift 2 ;;
      --limit)      limit="$2"; shift 2 ;;
      -*)           echo "Unknown option: $1" >&2; exit 1 ;;
      *)            shift ;;
    esac
  done

  local params="order=created_at.desc&limit=${limit}"

  if [[ -n "$since" ]]; then
    # Support relative times like "24h", "7d", "1h"
    if [[ "$since" =~ ^[0-9]+[hd]$ ]]; then
      local num="${since%[hd]}"
      local unit="${since: -1}"
      local seconds
      if [[ "$unit" == "h" ]]; then
        seconds=$((num * 3600))
      else
        seconds=$((num * 86400))
      fi
      since=$(date -u -v-"${seconds}"S +"%Y-%m-%dT%H:%M:%SZ" 2>/dev/null || \
              date -u -d "-${seconds} seconds" +"%Y-%m-%dT%H:%M:%SZ" 2>/dev/null)
    fi
    params="${params}&created_at=gte.${since}"
  fi

  [[ -n "$source" ]]     && params="${params}&source=eq.${source}"
  [[ -n "$category" ]]   && params="${params}&category=eq.${category}"
  [[ -n "$project" ]]    && params="${params}&project=eq.${project}"
  [[ -n "$unacked_by" ]] && params="${params}&acked_by=not.cs.%7B${unacked_by}%7D"

  sb_request GET "/shared_context?${params}"
  echo ""
}

cmd_ack() {
  local ids="" agent=""

  while [[ $# -gt 0 ]]; do
    case "$1" in
      --ids)   ids="$2"; shift 2 ;;
      --agent) agent="$2"; shift 2 ;;
      -*)      echo "Unknown option: $1" >&2; exit 1 ;;
      *)       shift ;;
    esac
  done

  if [[ -z "$ids" || -z "$agent" ]]; then
    echo "Error: --ids and --agent are required" >&2
    exit 1
  fi

  # Convert comma-separated IDs to JSON array
  local json_ids
  json_ids=$(echo "$ids" | python3 -c "import sys; print('[' + ','.join(sys.stdin.read().strip().split(',')) + ']')")

  local result
  result=$(sb_request POST "/rpc/ack_context" \
    -d "{\"entry_ids\": ${json_ids}, \"agent_name\": \"${agent}\"}")

  echo "{\"acknowledged\": ${result}, \"agent\": \"${agent}\"}"
}

cmd_status() {
  local result
  result=$(sb_request GET "/shared_context?limit=1&select=id")
  if [[ $? -eq 0 ]]; then
    echo '{"status": "ok", "message": "Agent Bridge is connected to Supabase"}'
  else
    echo '{"status": "error", "message": "Cannot reach Supabase"}' >&2
    exit 1
  fi
}

# Main
COMMAND="${1:-}"
shift || true

case "$COMMAND" in
  post)   cmd_post "$@" ;;
  get)    cmd_get "$@" ;;
  ack)    cmd_ack "$@" ;;
  status) cmd_status ;;
  -h|--help|help|"") usage ;;
  *)      echo "Unknown command: $COMMAND" >&2; usage; exit 1 ;;
esac
